{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "stream.beingmad.co" }],
      "destination": "https://www.beingmad.co/madplus",
      "permanent": true
    },
    {
      "source": "/studio",
      "destination": "https://madboulyjr-studio.sanity.studio",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|avatars/|favicon|robots|sitemap|admin|studio).*)",
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/admin/video-finalize.js": {
      "maxDuration": 60
    },
    "api/admin/upload-image.js": {
      "maxDuration": 30
    }
  }
}
